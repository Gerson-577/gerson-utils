{
  "publisher": "Gerson-577",
  "name": "gerson-utils",
  "displayName": "Gerson Utils",
  "version": "0.1.2",
  "private": false,
  "packageManager": "pnpm@10.27.0",
  "description": "A collection of handy VS Code utilities to improve development efficiency",
  "author": "gerson",
  "license": "MIT",
  "homepage": "https://github.com/Gerson-577/gerson-utils#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gerson-577/gerson-utils.git"
  },
  "bugs": {
    "url": "https://github.com/Gerson-577/gerson-utils/issues"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/index.cjs",
  "icon": "res/icon.png",
  "files": [
    "LICENSE.md",
    "dist/*",
    "res/*"
  ],
  "engines": {
    "vscode": "^1.97.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "gerson-utils.insertConsoleLog",
        "title": "Insert Console Log for Copied Variable"
      }
    ],
    "keybindings": [
      {
        "command": "gerson-utils.insertConsoleLog",
        "key": "shift+alt+v",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Gerson Utils",
      "properties": {}
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --external vscode",
    "dev": "nr build --watch --sourcemap",
    "prepare": "nr update",
    "update": "vscode-ext-gen --output src/generated/meta.ts",
    "lint": "eslint .",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "nr build",
    "release": "bumpp",
    "ext:package": "vsce package --no-dependencies",
    "ext:publish": "vsxpub --no-dependencies",
    "ext:publishOvsx":"ovsx publish --no-dependencies"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@antfu/ni": "^28.0.0",
    "@types/node": "^25.0.3",
    "@types/vscode": "^1.97.0",
    "@vscode/vsce": "^3.7.1",
    "bumpp": "^10.3.2",
    "eslint": "^9.39.2",
    "ovsx": "^0.10.7",
    "reactive-vscode": "^1.0.0-beta.2",
    "taze": "^19.9.2",
    "tsdown": "^0.19.0-beta.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16",
    "vscode-ext-gen": "^1.5.1",
    "vsxpub": "^0.1.2"
  }
}
